# SmartAgile backend — safe template to commit. Copy to `.env` or use the
# pre-created `backend/.env` (gitignored) and paste keys there.
# Do not commit real API keys.

# Log level for smartagile.* (and mail): DEBUG | INFO | WARNING — appears in the runserver terminal
# DJANGO_LOG_LEVEL=INFO

# --- Assistant LLM (see assistant/graph/llm_factory.py) ---
# auto = try Groq first, then OpenAI if Groq fails or is missing
# groq = only Groq | openai = only OpenAI
LLM_PROVIDER=auto

# Groq (primary when LLM_PROVIDER=auto and this is set)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (fallback in auto mode, or primary when LLM_PROVIDER=openai)
OPENAI_API_KEY=
# Optional: Azure / proxy (leave empty for api.openai.com)
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# 0 = rule-based intent; 1 = small LLM for intent (uses same Groq/OpenAI chain)
ASSISTANT_LLM_CLASSIFY=0
# 1 = LLM rewrites answers from app data; 0 = templates only
ASSISTANT_LLM_SYNTHESIZE=1

# --- Email (Gmail: use an App Password, not your normal login) ---
# DEFAULT_FROM_EMAIL usually matches EMAIL_HOST_USER
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=your-email@gmail.com
# Optional: use console backend for local testing (no real send)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- Optional: Celery (override defaults) ---
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# CELERY_TASK_ALWAYS_EAGER=true
