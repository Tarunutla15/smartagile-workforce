# SmartAgile front-end — copy to .env.local (gitignored)
# https://create-react-app.dev/docs/adding-custom-environment-variables/

# Dev proxy target (setupProxy.js) — Django API
REACT_APP_PROXY_TARGET=http://127.0.0.1:8000

# Axios base URL. Leave empty in dev to use same-origin + proxy.
# REACT_APP_API_BASE=

# Used for profile photo URLs when media is on another host
REACT_APP_API_ORIGIN=http://127.0.0.1:8000

# Must match desktop-agent SMARTAGILE_LOCAL_PORT (default 38475)
REACT_APP_AGENT_LOCAL_PORT=38475
